# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# RapidAPI key for CNN Fear & Greed Index
# Sign up at https://rapidapi.com and subscribe to "Fear and Greed Index" API
RAPIDAPI_KEY=your_rapidapi_key_here

# SQLite database file path (relative or absolute)
DB_PATH=signals.db

# Optional: Claude model to use for signal estimation
CLAUDE_MODEL=claude-sonnet-4-6

# Optional: max markets to process per run (leave blank for all)
MAX_MARKETS=
